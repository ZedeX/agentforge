{
  "title": "Agent Platform Overview",
  "comment": "Placeholder dashboard - import from Grafana.com or build via UI. Required panels per doc 09 §11.2: task success rate, hallucination rate, tool call success, model cost, token consumption, drift trend, quota usage.",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Task Success Rate",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "agent:task_success_rate", "legendFormat": "{{service}}"}]
    },
    {
      "id": 2,
      "title": "Hallucination Rate",
      "type": "gauge",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "agent:hallucination_rate", "legendFormat": "{{service}}"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [
        {"color": "green", "value": null},
        {"color": "yellow", "value": 0.05},
        {"color": "red", "value": 0.10}
      ]}}}
    },
    {
      "id": 3,
      "title": "Tool Call Success",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "agent:tool_call_success_rate", "legendFormat": "{{tool_id}}"}]
    },
    {
      "id": 4,
      "title": "Active Agent Instances",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "agent:active_instances", "legendFormat": "{{service}}"}]
    },
    {
      "id": 5,
      "title": "Model Cost (per min)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "targets": [{"expr": "agent:cost_per_minute", "legendFormat": "{{tenant_id}}"}]
    },
    {
      "id": 6,
      "title": "Token Consumption",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "targets": [{"expr": "agent:token_per_minute", "legendFormat": "{{model}} - {{tenant_id}}"}]
    },
    {
      "id": 7,
      "title": "Drift Score Trend",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 14},
      "targets": [{"expr": "agent_drift_score", "legendFormat": "{{agent_id}}"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [
        {"color": "green", "value": null},
        {"color": "yellow", "value": 0.3},
        {"color": "orange", "value": 0.5},
        {"color": "red", "value": 0.7}
      ]}}}
    }
  ]
}
