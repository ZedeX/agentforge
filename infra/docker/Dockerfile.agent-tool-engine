# agent-tool-engine service Dockerfile.
# Build: docker build -t agentplatform/agent-tool-engine:1.0.0 -f Dockerfile.agent-tool-engine --build-arg SERVICE_NAME=agent-tool-engine -f Dockerfile.template .

FROM agentplatform/base:17-jre-skywalking-9.7

LABEL service="agent-tool-engine"
LABEL tier="service"

ENV SW_AGENT_NAME="agent-platform-agent-tool-engine"
ENV SW_COLLECTOR_BACKEND_SERVICE="skywalking-oap.agent-platform-infra:11800"

EXPOSE 8090 9090

VOLUME ["/var/log/agent-platform"]

HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
  CMD curl -fs http://localhost:8090/actuator/health || exit 1