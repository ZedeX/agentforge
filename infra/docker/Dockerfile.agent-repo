# agent-repo service Dockerfile.
# Build: docker build -t agentplatform/agent-repo:1.0.0 -f Dockerfile.agent-repo --build-arg SERVICE_NAME=agent-repo -f Dockerfile.template .

FROM agentplatform/base:17-jre-skywalking-9.7

LABEL service="agent-repo"
LABEL tier="service"

ENV SW_AGENT_NAME="agent-platform-agent-repo"
ENV SW_COLLECTOR_BACKEND_SERVICE="skywalking-oap.agent-platform-infra:11800"

EXPOSE 8096 9096

VOLUME ["/var/log/agent-platform"]

HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
  CMD curl -fs http://localhost:8096/actuator/health || exit 1