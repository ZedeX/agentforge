# agent-observability service Dockerfile.
# Build: docker build -t agentplatform/agent-observability:1.0.0 -f Dockerfile.agent-observability --build-arg SERVICE_NAME=agent-observability -f Dockerfile.template .

FROM agentplatform/base:17-jre-skywalking-9.7

LABEL service="agent-observability"
LABEL tier="service"

ENV SW_AGENT_NAME="agent-platform-agent-observability"
ENV SW_COLLECTOR_BACKEND_SERVICE="skywalking-oap.agent-platform-infra:11800"

EXPOSE 8104

VOLUME ["/var/log/agent-platform"]

HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
  CMD curl -fs http://localhost:8104/actuator/health || exit 1