# Lombok 配置（影响所有子模块）
# 文档: https://projectlombok.org/features/configuration

# 阻止 Lombok 向上查找更多配置文件（确保此文件是配置根）
config.stopBubbling = true

# 在 Lombok 生成的方法上添加 @lombok.Generated 注解
# 这样 JaCoCo 0.8.0+ 会自动排除这些方法，避免生成代码拉低覆盖率
# 关键场景：@Data/@Builder/@AllArgsConstructor 生成的 builder/equals/hashCode/toString
#           存在大量分支，单测通常不覆盖，导致 branch coverage 失真
lombok.addLombokGeneratedAnnotation = true

# 字段默认使用链式 setter（@Accessors(chain=true) 等效），但项目未启用，保持默认
# 仅供未来扩展参考
